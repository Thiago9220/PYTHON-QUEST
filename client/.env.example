# =============================================================
# Python Quest — variáveis de ambiente do cliente (Vite)
# =============================================================
# 1. Copie este arquivo para .env (mesma pasta de package.json)
# 2. Preencha com os valores do seu projeto Supabase:
#    Painel Supabase -> Project Settings -> API
# 3. Reinicie o dev server (npm run dev) após editar.
# -------------------------------------------------------------

# URL do projeto (ex: https://abcd1234.supabase.co)
VITE_SUPABASE_URL=

# anon / public key (a "anon key", NUNCA a service_role)
VITE_SUPABASE_ANON_KEY=

# (opcional) Site key do Cloudflare Turnstile para CAPTCHA no login/registro.
# Deixe vazio para desabilitar o widget.
VITE_TURNSTILE_SITE_KEY=
